# Example: HTTPS reverse proxy for PPCSexRx (port 443 -> Shiny 3838)
# 1. Point DNS A record: ppcsexrx.guanglab.org -> 132.226.153.186
# 2. sudo cp deploy/nginx-ppcsexrx.conf.example /etc/nginx/sites-available/ppcsexrx.conf
# 3. sudo ln -sf /etc/nginx/sites-available/ppcsexrx.conf /etc/nginx/sites-enabled/
# 4. sudo certbot --nginx -d ppcsexrx.guanglab.org
# 5. sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name ppcsexrx.guanglab.org;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name ppcsexrx.guanglab.org;
    client_max_body_size 50M;

    location / {
        proxy_pass http://127.0.0.1:3838;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
    }

    # certbot will inject ssl_certificate lines here
}
